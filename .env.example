# Only user-tunable settings live here. Container-internal paths
# (yt-dlp binary location, /downloads, /cookies, /data, the downloader's
# in-network URL) are baked into the images and compose file — those are
# not user concerns.

# Maximum number of yt-dlp jobs that may run concurrently.
DOWNLOADER_MAX_PARALLEL=2

# Host-side directories that get bind-mounted into the containers.
HOST_DOWNLOAD_DIR=./downloads
HOST_COOKIES_DIR=./cookies
HOST_DATA_DIR=./data

# Host port the web UI is published on (ignored when using the
# tailscale override — there the UI is only reachable via the tailnet).
WEB_PORT=3000

# --- Tailscale sidecar (only used with docker-compose.tailscale.yml) ---
# Generate a reusable, ephemeral pre-auth key at
# https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=
TS_HOSTNAME=yt-dlp-ui
