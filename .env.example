# --- Downloader service ---
# Number of yt-dlp jobs that may run concurrently.
DOWNLOADER_MAX_PARALLEL=2

# Path to the yt-dlp binary inside the downloader container.
YTDLP_PATH=yt-dlp

# --- Shared paths (inside containers) ---
DOWNLOAD_DIR=/downloads
COOKIES_DIR=/cookies

# --- Web service ---
# SQLite database file (inside the web container).
DB_PATH=/data/app.db

# Downloader URL as seen from the web service.
DOWNLOADER_URL=http://downloader:8080

# Ports
WEB_PORT=3000
DOWNLOADER_PORT=8080

# --- Tailscale sidecar (only used with docker-compose.tailscale.yml) ---
# Generate a reusable, ephemeral pre-auth key at https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=
TS_HOSTNAME=yt-dlp-ui
